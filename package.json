{
  "name": "staycore-booking-toolkit",
  "version": "0.0.0",
  "private": true,
  "description": "STAYCORE Direct Booking Toolkit — SDK, CLI npx & Claude Code Skill",
  "license": "MIT",
  "author": "Keenqo <david@keenqo.fr>",
  "homepage": "https://github.com/Keenqo-Dev-Team/staycore-booking-toolkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/Keenqo-Dev-Team/staycore-booking-toolkit.git"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build --filter=./packages/* && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
