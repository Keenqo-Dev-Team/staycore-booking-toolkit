{
  "name": "create-staycore-site",
  "version": "0.2.0",
  "description": "Scaffold a direct booking website wired to the Stay'Core PMS in seconds.",
  "license": "MIT",
  "author": "Keenqo <david@keenqo.fr>",
  "homepage": "https://github.com/Keenqo-Dev-Team/staycore-booking-toolkit/tree/main/packages/create-staycore-site",
  "repository": {
    "type": "git",
    "url": "https://github.com/Keenqo-Dev-Team/staycore-booking-toolkit.git",
    "directory": "packages/create-staycore-site"
  },
  "type": "module",
  "bin": {
    "create-staycore-site": "./bin/cli.mjs"
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-templates.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "echo \"(lint placeholder)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist templates",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@staycore/booking-sdk": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "staycore",
    "booking",
    "scaffolding",
    "create-app",
    "vite",
    "react"
  ]
}
