{
  "name": "@staycore/booking-sdk",
  "version": "0.2.1",
  "description": "TypeScript SDK for the Stay'Core PMS public booking engine API (v1)",
  "license": "MIT",
  "author": "Keenqo <david@keenqo.fr>",
  "homepage": "https://github.com/Keenqo-Dev-Team/staycore-booking-toolkit/tree/main/packages/sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/Keenqo-Dev-Team/staycore-booking-toolkit.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "echo \"(lint placeholder)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "react": "^18.3.1",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "staycore",
    "booking",
    "pms",
    "react",
    "sdk",
    "vacation-rental"
  ]
}
